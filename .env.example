# Copy to .env and paste your key from: Obsidian > Settings > Local REST API > API Key
OBSIDIAN_API_KEY=YOUR_API_KEY
OBSIDIAN_REST_URL=http://localhost:27123

# OpenRouter key (used for the GLM provider slot in /wiki-research, /wiki-debate)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_API_KEY
